// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum Provider {
  EMAIL
  GOOGLE
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
}

enum FileProvider {
  CLOUDINARY
}

// ─────────────────────────────────────────────
// User — Authentication identity
// ─────────────────────────────────────────────
model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String?
  firstName    String?
  lastName     String?
  avatar       String?
  role         Role       @default(USER)
  provider     Provider   @default(EMAIL)
  status       UserStatus @default(PENDING_VERIFICATION)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // ── Email Verification ──────────────────────────
  emailVerifiedAt            DateTime?
  emailVerificationToken     String?
  emailVerificationExpiresAt DateTime?

  // ── Password Reset ──────────────────────────────
  passwordResetToken     String?
  passwordResetExpiresAt DateTime?
  passwordChangedAt      DateTime?

  // ── Email Change ────────────────────────────────
  pendingEmail                      String?
  pendingEmailVerificationToken     String?
  pendingEmailVerificationExpiresAt DateTime?

  // ── Two-Factor Authentication (TOTP) ────────────
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?

  // ── Account Lockout ─────────────────────────────
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  sessions Session[]
  founder  Founder?
  files    File[]

  @@map("users")
}

// ─────────────────────────────────────────────
// Session — Refresh token tracking per device
// ─────────────────────────────────────────────
model Session {
  id               String    @id @default(uuid())
  userId           String
  refreshTokenHash String
  ipAddress        String?
  userAgent        String?
  expiresAt        DateTime
  lastUsedAt       DateTime  @default(now())
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ─────────────────────────────────────────────
// Founder — Business entity, owns Waitlists
// ─────────────────────────────────────────────
model Founder {
  id        String   @id @default(uuid())
  userId    String   @unique
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  waitlists Waitlist[]

  @@map("founders")
}

// ─────────────────────────────────────────────
// File — Uploaded file metadata (not binary)
// ─────────────────────────────────────────────
model File {
  id               String       @id @default(uuid())
  publicId         String
  url              String
  secureUrl        String
  originalName     String
  fileName         String
  mimeType         String
  format           String
  bytes            Int
  width            Int?
  height           Int?
  folder           String
  provider         FileProvider @default(CLOUDINARY)
  uploadedByUserId String
  createdAt        DateTime     @default(now())

  uploadedBy     User       @relation(fields: [uploadedByUserId], references: [id], onDelete: Cascade)
  waitlistLogos  Waitlist[] @relation("WaitlistLogo")
  brandingLogos  Branding[] @relation("BrandingLogo")

  @@index([uploadedByUserId])
  @@map("files")
}

// ─────────────────────────────────────────────
// Waitlist — A single waitlist owned by a Founder
// ─────────────────────────────────────────────
model Waitlist {
  id          String   @id @default(uuid())
  founderId   String
  name        String
  tagline     String
  description String?
  slug        String   @unique
  logoId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  founder      Founder       @relation(fields: [founderId], references: [id], onDelete: Cascade)
  logo         File?         @relation("WaitlistLogo", fields: [logoId], references: [id], onDelete: SetNull)
  branding     Branding?
  widget       Widget?
  participants Participant[]

  @@index([founderId])
  @@map("waitlists")
}

// ─────────────────────────────────────────────
// Branding — Visual identity for a waitlist
// ─────────────────────────────────────────────
model Branding {
  id              String   @id @default(uuid())
  waitlistId      String   @unique
  logoId          String?
  primaryColor    String
  secondaryColor  String
  backgroundColor String
  buttonColor     String
  font            String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  waitlist Waitlist @relation(fields: [waitlistId], references: [id], onDelete: Cascade)
  logo     File?    @relation("BrandingLogo", fields: [logoId], references: [id], onDelete: SetNull)

  @@map("brandings")
}

// ─────────────────────────────────────────────
// Widget — Embed metadata for a waitlist
// ─────────────────────────────────────────────
model Widget {
  id         String   @id @default(uuid())
  waitlistId String   @unique
  scriptUrl  String
  embedCode  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  waitlist Waitlist @relation(fields: [waitlistId], references: [id], onDelete: Cascade)

  @@map("widgets")
}

// ─────────────────────────────────────────────
// Participant — A user who joined a waitlist
// ─────────────────────────────────────────────
model Participant {
  id            String   @id @default(uuid())
  waitlistId    String
  email         String
  position      Int
  referralCode  String   @unique
  referredById  String?
  referralCount Int      @default(0)
  createdAt     DateTime @default(now())

  waitlist   Waitlist      @relation(fields: [waitlistId], references: [id], onDelete: Cascade)
  referredBy Participant?  @relation("Referrals", fields: [referredById], references: [id])
  referrals  Participant[] @relation("Referrals")

  @@unique([waitlistId, email])
  @@map("participants")
}
