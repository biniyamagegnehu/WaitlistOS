# Environment Configuration

# Database
DATABASE_URL=

# Redis (Bull Queue)
REDIS_HOST=
REDIS_PORT=

# JWT Auth
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# App
NODE_ENV=development
FRONTEND_URL=http://localhost:3001
# Optional comma-separated extra origins (production example):
# CORS_ORIGINS=https://waitlistos.up.railway.app

# Resend Email
RESEND_API_KEY=

# Email Config (Resend)
EMAIL_FROM=

# Next.js App URL (for generating referral links)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Redis Config (for Bull Queue)
REDIS_URL=redis://localhost:6379

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
# Production example:
# GOOGLE_CALLBACK_URL=https://your-api.up.railway.app/api/auth/google/callback

# Cloudinary (File Storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Chapa Payments
CHAPA_SECRET_KEY=
CHAPA_PUBLIC_KEY=
CHAPA_WEBHOOK_SECRET=
CHAPA_BASE_URL=https://api.chapa.co/v1

# Subscription Plans (USD)
PLAN_CURRENCY=USD
FREE_MAX_WAITLISTS=1
FREE_MAX_PARTICIPANTS=500
PLAN_STARTER_PRICE=19
PLAN_STARTER_MAX_WAITLISTS=5
PLAN_STARTER_MAX_PARTICIPANTS=5000
PLAN_PRO_PRICE=49
